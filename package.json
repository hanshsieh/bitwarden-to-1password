{
  "name": "bitwarden-to-1password",
  "version": "0.1.0",
  "description": "CLI tool to migrate a Bitwarden vault export to 1Password, including attachments and custom fields",
  "type": "module",
  "bin": {
    "bitwarden-to-1password": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "bitwarden",
    "1password",
    "password-manager",
    "migration",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@1password/sdk": "^0.4.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
